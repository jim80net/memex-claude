#!/bin/sh
# skill-router hook entry point.
# Tries the prebuilt binary first, falls back to node, or gracefully fails.
# When the binary is missing, triggers a background download so the next
# invocation uses the compiled binary instead of the tsx fallback.
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$DIR/.." && pwd)"

# 1. Prebuilt binary
if [ -f "$DIR/skill-router.bin" ]; then
  case "$(uname -s)" in
    Darwin*) export DYLD_LIBRARY_PATH="$DIR${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}" ;;
    *)       export LD_LIBRARY_PATH="$DIR${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" ;;
  esac
  exec "$DIR/skill-router.bin" "$@"
fi

# 1b. Binary missing — download it in background for next invocation.
# Uses a lock file to prevent concurrent installs.
if [ -x "$DIR/install.sh" ] && [ ! -f "$DIR/.installing.lock" ]; then
  (
    touch "$DIR/.installing.lock"
    "$DIR/install.sh" >"$DIR/.install.log" 2>&1
    rm -f "$DIR/.installing.lock"
  ) &
fi

# 2. Fallback: node + tsx (development or if binary not installed)
# cd to ROOT so node resolves tsx from the plugin's own node_modules,
# not from whatever CWD the hook was invoked with.
if command -v node >/dev/null 2>&1; then
  if [ -d "$ROOT/node_modules" ]; then
    cd "$ROOT"
    exec node --import tsx "$ROOT/src/main.ts" "$@"
  fi
  # Try installing deps first
  if [ -f "$ROOT/pnpm-lock.yaml" ] && command -v pnpm >/dev/null 2>&1; then
    pnpm --dir "$ROOT" install --frozen-lockfile --silent >&2 2>/dev/null
    cd "$ROOT"
    exec node --import tsx "$ROOT/src/main.ts" "$@"
  fi
fi

# 3. Graceful failure — output empty hook response, warn on stderr
echo '{}'
echo "skill-router: no binary found and node is not available. Install from https://github.com/jim80net/claude-skill-router/releases" >&2
