{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT} && [ -d node_modules ] || npm install --silent >&2",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT} && node --import tsx src/main.ts",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT} && node --import tsx src/main.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT} && node --import tsx src/main.ts",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
